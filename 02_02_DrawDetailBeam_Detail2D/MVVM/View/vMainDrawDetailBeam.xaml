<Window
    x:Class="_02_02_DrawDetailBeam_Detail2D.MVVM.View.vMainDrawDetailBeam"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:_02_02_DrawDetailBeam_Detail2D.MVVM.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="DetailBeam2D"
    Title="Vẽ mặt cắt dầm"
    ResizeMode="NoResize"
    SizeToContent="WidthAndHeight"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/00_00_DHHShareLibrary;component/Themes/Style.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="52" />
        </Grid.RowDefinitions>
        <TabControl SelectedIndex="1" TabStripPlacement="Left">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Height" Value="{Binding Height, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type TabControl}}}" />
                </Style>
            </TabControl.Resources>
            <TabItem>
                <Grid Width="600" Height="Auto">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>
                    <HeaderedContentControl
                        HorizontalAlignment="Stretch"
                        Header="Tiết diện:"
                        Style="{DynamicResource RoundedHeaderBorderStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                HorizontalAlignment="Left"
                                Style="{DynamicResource TextBlockStyle}"
                                Text="b × h =                " />
                            <TextBox Width="80" Style="{DynamicResource TextBoxStyle}" />
                            <TextBlock
                                HorizontalAlignment="Left"
                                Style="{DynamicResource TextBlockStyle}"
                                Text="  ×  " />
                            <TextBox Width="80" Style="{DynamicResource TextBoxStyle}" />
                        </StackPanel>
                    </HeaderedContentControl>
                    <HeaderedContentControl
                        Grid.Row="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Header="Thép chủ:"
                        Style="{DynamicResource RoundedHeaderBorderStyle}">
                        <Grid Margin="0,-5,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                VerticalAlignment="Center"
                                Text="Thép lớp trên:" />
                            <StackPanel
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <TextBox
                                    Width="50"
                                    Height="30"
                                    Style="{StaticResource TextBoxStyle}" />
                                <TextBlock VerticalAlignment="Center" Text="   Ø   " />
                                <ComboBox
                                    Width="50"
                                    Height="35"
                                    Style="{StaticResource ComboBox}" />
                            </StackPanel>
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="Thép lớp trên:" />
                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="45,0,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <TextBox
                                    Width="50"
                                    Height="30"
                                    Style="{StaticResource TextBoxStyle}" />
                                <TextBlock VerticalAlignment="Center" Text="   Ø   " />
                                <ComboBox
                                    Width="50"
                                    Height="35"
                                    Style="{StaticResource ComboBox}" />
                            </StackPanel>
                        </Grid>
                    </HeaderedContentControl>
                    <HeaderedContentControl
                        Grid.Row="2"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Header="Thép chủ:"
                        Style="{DynamicResource RoundedHeaderBorderStyle}">
                        <Grid Margin="0,-5,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                VerticalAlignment="Center"
                                Text="Thép lớp trên:" />
                            <StackPanel
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <TextBox
                                    Width="50"
                                    Height="30"
                                    Style="{StaticResource TextBoxStyle}" />
                                <TextBlock VerticalAlignment="Center" Text="   Ø   " />
                                <ComboBox
                                    Width="50"
                                    Height="35"
                                    Style="{StaticResource ComboBox}" />
                            </StackPanel>
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="Thép lớp trên:" />
                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="45,0,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <TextBox
                                    Width="50"
                                    Height="30"
                                    Style="{StaticResource TextBoxStyle}" />
                                <TextBlock VerticalAlignment="Center" Text="   Ø   " />
                                <ComboBox
                                    Width="50"
                                    Height="35"
                                    Style="{StaticResource ComboBox}" />
                            </StackPanel>
                        </Grid>
                    </HeaderedContentControl>
                </Grid>
                <TabItem.Header>
                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                        <TextBlock
                            FontStyle="Normal"
                            FontWeight="DemiBold"
                            Text="Vẽ nhanh" />
                    </StackPanel>
                </TabItem.Header>
            </TabItem>
            <TabItem>
                <Grid Width="1200">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="400" />
                        <RowDefinition Height="200" />
                    </Grid.RowDefinitions>
                    <Canvas
                        x:Name="viewCanvas"
                        Grid.Row="1"
                        Margin="5"
                        Background="WhiteSmoke" />
                </Grid>
                <TabItem.Header>
                    <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                        <TextBlock
                            FontStyle="Normal"
                            FontWeight="DemiBold"
                            Text="Vẽ chi tiết" />
                    </StackPanel>
                </TabItem.Header>
            </TabItem>
        </TabControl>
        <DockPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            LastChildFill="True">
            <Button
                Width="140"
                Height="40"
                Margin="3"
                Command="{Binding BtnChonDam}"
                CommandParameter="{Binding ElementName=DetailBeam2D}"
                Content="Chọn dầm"
                FontFamily="Arial"
                Style="{DynamicResource ButtonStyle}" />
            <Button
                Width="140"
                Height="40"
                Margin="3"
                Command="{Binding BtnOK}"
                CommandParameter="{Binding ElementName=DetailBeam2D}"
                Content="Vẽ thép"
                FontFamily="Arial"
                Style="{DynamicResource ButtonStyle}" />
            <Button
                Width="140"
                Height="40"
                Margin="3"
                Command="{Binding BtnCancel}"
                CommandParameter="{Binding ElementName=DetailBeam2D}"
                Content="Hủy bỏ"
                FontFamily="Arial"
                Style="{DynamicResource ButtonStyle}" />
        </DockPanel>
    </Grid>
</Window>
