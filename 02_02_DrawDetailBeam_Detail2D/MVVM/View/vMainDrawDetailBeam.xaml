<Window
    x:Class="_02_02_DrawDetailBeam_Detail2D.MVVM.View.vMainDrawDetailBeam"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:_02_02_DrawDetailBeam_Detail2D.MVVM.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="DetailBeam2D"
    Title="Vẽ mặt cắt dầm"
    SizeToContent="WidthAndHeight"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/00_00_DHHShareLibrary;component/Themes/Style.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="52" />
        </Grid.RowDefinitions>
        <TabControl TabStripPlacement="Left" SelectedIndex="1">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Height" 
                            Value="{Binding Height, 
                                    RelativeSource={RelativeSource FindAncestor, 
                                    AncestorType={x:Type TabControl}}}"/>
                </Style>
            </TabControl.Resources>
            <TabItem>
                <Grid Width="600" Height="Auto">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <HeaderedContentControl Style="{DynamicResource RoundedHeaderBorderStyle}" 
                        Header="Tiết diện:" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource TextBlockStyle}" 
                                       HorizontalAlignment="Left" Text="b × h = "/>
                            <TextBox Style="{DynamicResource TextBoxStyle}" Width="80"/>
                            <TextBlock Style="{DynamicResource TextBlockStyle}" 
                                       HorizontalAlignment="Left" Text="  ×  "/>
                            <TextBox Style="{DynamicResource TextBoxStyle}" Width="80"/>
                        </StackPanel>
                    </HeaderedContentControl>
                    <HeaderedContentControl 
                        Grid.Row="1"
                        Style="{DynamicResource RoundedHeaderBorderStyle}" 
                        Header="Thép chủ:"
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Center">
                        <Grid Margin="0,-5,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Text="Thép lớp trên:" 
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="1" 
                                        HorizontalAlignment="Right">
                                <TextBox   Style="{StaticResource TextBoxStyle}" Width="50" Height="30"/>
                                <TextBlock Text="   Ø   " VerticalAlignment="Center" />
                                <ComboBox Style="{StaticResource ComboBox}" Width="50" Height="35"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Thép lớp trên:" 
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" 
                                        HorizontalAlignment="Right"
                                        Margin="45,0,0,0">
                                <TextBox   Style="{StaticResource TextBoxStyle}" Width="50" Height="30"/>
                                <TextBlock Text="   Ø   " VerticalAlignment="Center" />
                                <ComboBox Style="{StaticResource ComboBox}" Width="50" Height="35"/>
                            </StackPanel>
                        </Grid>
                    </HeaderedContentControl>
                    <HeaderedContentControl 
                         Grid.Row="2"
                         Style="{DynamicResource RoundedHeaderBorderStyle}" 
                         Header="Thép chủ:"
                         HorizontalAlignment="Stretch" 
                         VerticalAlignment="Center">
                        <Grid Margin="0,-5,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Text="Thép lớp trên:" 
                    VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="1" 
                     HorizontalAlignment="Right">
                                <TextBox   Style="{StaticResource TextBoxStyle}" Width="50" Height="30"/>
                                <TextBlock Text="   Ø   " VerticalAlignment="Center" />
                                <ComboBox Style="{StaticResource ComboBox}" Width="50" Height="35"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Thép lớp trên:" 
                    VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" 
                     HorizontalAlignment="Right"
                     Margin="45,0,0,0">
                                <TextBox   Style="{StaticResource TextBoxStyle}" Width="50" Height="30"/>
                                <TextBlock Text="   Ø   " VerticalAlignment="Center" />
                                <ComboBox Style="{StaticResource ComboBox}" Width="50" Height="35"/>
                            </StackPanel>
                        </Grid>
                    </HeaderedContentControl>
                </Grid>
                <TabItem.Header >
                    <StackPanel HorizontalAlignment="Left" 
                                Orientation="Horizontal">
                        <TextBlock
                            FontStyle="Normal"
                            FontWeight="DemiBold"
                            Text="Vẽ nhanh" />
                    </StackPanel>
                </TabItem.Header>
            </TabItem>
            <TabItem>
                <Grid Width="1200">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="400"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>
                    <Canvas x:Name="viewCanvas"
                            Background="WhiteSmoke"
                            Grid.Row="1" Margin="5">
                    </Canvas>
                </Grid>
                <TabItem.Header>
                    <StackPanel HorizontalAlignment="Left" 
                                Orientation="Horizontal">
                        <TextBlock
                            FontStyle="Normal"
                            FontWeight="DemiBold"
                            Text="Vẽ chi tiết"/>
                    </StackPanel>
                </TabItem.Header>
            </TabItem>
        </TabControl>
        <DockPanel Grid.Row="2" LastChildFill="True" HorizontalAlignment="Right">
            <Button
                 Width="140" Height="40"
                Margin="3"
                Command="{Binding BtnChonDam}"
                CommandParameter="{Binding ElementName=DetailBeam2D}"
                Content="Chọn dầm" FontFamily="Arial"
                Style="{DynamicResource ButtonStyle}" />
            <Button
                 Width="140" Height="40"
                Margin="3"
                Command="{Binding BtnOK}"
                CommandParameter="{Binding ElementName=DetailBeam2D}"
                Content="Vẽ thép" FontFamily="Arial"
                Style="{DynamicResource ButtonStyle}" />
            <Button
                Width="140" Height="40"
                Margin="3"
                Command="{Binding BtnCancel}"
                CommandParameter="{Binding ElementName=DetailBeam2D}"
                Content="Hủy bỏ" FontFamily="Arial"
                Style="{DynamicResource ButtonStyle}" />
        </DockPanel>
    </Grid>
</Window>
 